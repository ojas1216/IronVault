# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=mdm_db
POSTGRES_USER=mdm_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://mdm_user:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/mdm_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379/0

# ─── JWT Security ─────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_128_CHAR_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin Account ────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@yourcompany.com
# Generate: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
FIRST_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH

# ─── Firebase (FCM) ───────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
# OR paste inline:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── APNs (iOS Push) ──────────────────────────────────────────────────────────
APNS_KEY_PATH=apns_key.p8
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_BUNDLE_ID=com.yourcompany.mdmagent
APNS_USE_SANDBOX=false

# ─── App Settings ────────────────────────────────────────────────────────────
APP_NAME=Enterprise MDM System
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=https://admin.yourcompany.com,http://localhost:3000

# ─── OTP Settings ────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_SECONDS=900

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_OTP=10/minute

# ─── Dashboard ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
