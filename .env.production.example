# =============================================================================
# IronVault MDM — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the filled .env file to version control.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="IronVault MDM"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_USER=mdm_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
POSTGRES_DB=mdm_db
DATABASE_URL=postgresql://mdm_user:CHANGE_THIS_STRONG_DB_PASSWORD@postgres:5432/mdm_db
ASYNC_DATABASE_URL=postgresql+asyncpg://mdm_user:CHANGE_THIS_STRONG_DB_PASSWORD@postgres:5432/mdm_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_STRONG_REDIS_PASSWORD@redis:6379/0

# ── JWT / Authentication ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Enrollment ────────────────────────────────────────────────────────────────
# This code is given to employees/agents to enroll devices.
# Change immediately after first deployment.
ENROLLMENT_CODE=CHANGE_THIS_TO_YOUR_COMPANY_SECRET_CODE

# ── Encryption (device data at rest) ─────────────────────────────────────────
# Generate: openssl rand -base64 32
DEVICE_DATA_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ── CORS (your admin dashboard domain) ───────────────────────────────────────
# Comma-separated list of allowed origins. No trailing slash.
ALLOWED_ORIGINS=["https://admin.yourdomain.com"]

# ── Trusted Hosts ─────────────────────────────────────────────────────────────
# Your API domain(s). Prevents Host header injection.
ALLOWED_HOSTS=["api.yourdomain.com","yourdomain.com"]

# ── Firebase Cloud Messaging (Android push) ───────────────────────────────────
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Apple Push Notification Service (iOS push) ───────────────────────────────
# Generate .p8 key from https://developer.apple.com/account/resources/authkeys/list
APNS_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_BUNDLE_ID=com.yourcompany.mdmagent
APNS_USE_SANDBOX=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=900
