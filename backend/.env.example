# Application
SECRET_KEY=your-super-secret-key-min-32-chars-change-this
DEBUG=false
ENROLLMENT_CODE=COMPANY_ENROLL_2024_SECURE

# Database
DATABASE_URL=postgresql://mdm_user:mdm_pass@localhost:5432/mdm_db
ASYNC_DATABASE_URL=postgresql+asyncpg://mdm_user:mdm_pass@localhost:5432/mdm_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase (FCM)
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project

# APNs (iOS push)
APNS_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.yourcompany.mdmagent
APNS_USE_SANDBOX=false

# Encryption
DEVICE_DATA_ENCRYPTION_KEY=32-char-aes-key-here-change-this!

# CORS
ALLOWED_ORIGINS=["https://admin.yourcompany.com"]
