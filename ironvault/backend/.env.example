# IronVault Backend Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://ironvault:yourpassword@localhost/ironvault

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
DEVICE_HMAC_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_2

# Admin login
ADMIN_EMAIL=admin@yourcompany.com
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH

# Firebase
FIREBASE_CREDENTIALS=firebase_credentials.json

# Server
PORT=8000
HOST=0.0.0.0
